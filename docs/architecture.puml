@startuml architecture

class FSA {
  - State[] states
  - Transition[] transitions
  - State startState
  - State[] acceptStates
  - Alphabet alphabet
  + FSA(states: State[], transitions: Transition[], startState: State, acceptStates: State[], alphabet: Alphabet)
  + validateTransitions(transitions: Transition[], alphabet: Alphabet)
  + addState(state: State)
  + addTransition(transition: Transition)
  + setStartState(state: State)
  + addAcceptState(states: State[])
  + toJSON(): FSAJSON
  + static fromJSON(json: FSAJSON): FSA
}

class DFA {
  - State emptyState
  + DFA(states: State[], transitions: Transition[], startState: State, acceptStates: State[], alphabet: Alphabet)
  + validateDFA()
  + addTransition(transition: Transition)
  + static fromJSON(json: FSAJSON): DFA
}

class NFA {
  + NFA(states: State[], transitions: Transition[], startState: State, acceptStates: State[], alphabet: Alphabet)
  + stateSetName(states: Set<State>): string
  + stateSetKey(states: Set<State>): string
  + epsilonClosure(state: State): Set<State>
  + move(states: Set<State>, symbol: string): Set<State>
  + removeUnreachableStates(dfa: DFA)
  + toDFA(removeUnreachableStates: boolean): DFA
  + static fromJSON(json: FSAJSON): NFA
}

class State {
  - string name
  + State(name: string)
}

class Transition {
  - State from
  - State to
  - string symbol
  + Transition(from: State, to: State, symbol: string)
}

class Alphabet {
  - Set<string> symbols
  + Alphabet(symbols: string[])
  + addSymbol(symbol: string)
  + removeSymbol(symbol: string)
  + hasSymbol(symbol: string): boolean
  + getSymbols(): string[]
}

class ValidationError {
  - string message
  + ValidationError(message: string)
}

FSA <|-- DFA
FSA <|-- NFA
DFA o-- State
DFA o-- Transition
DFA o-- Alphabet
NFA o-- State
NFA o-- Transition
NFA o-- Alphabet
Transition *-- State
FSA ..> ValidationError
DFA ..> ValidationError
@enduml
